


# STEP 1: Define the variable grade so the program can run
grade = 75 

if grade >= 60:
    print('Passed') # Correct indentation means this runs IF the condition is True
    
# This statement must be at zero indentation (flush left) 
# to ensure it runs after the 'if' block, regardless of passing or failing.
print('Good job!') 



